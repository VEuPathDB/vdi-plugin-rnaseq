#!/usr/bin/perl

use strict;
use DBI;
use DBI qw(:sql_types);
use FindBin;
use lib "$FindBin::Bin/../lib/perl";
use RnaSeqHandlerCommon;
use DbiBatchExecutor;
use BigWigUtils;
use File::Copy;
use JSON qw( );


my $DEBUG = 0;

my @envVars = ('DB_HOST', 'DB_PORT', 'DB_NAME', 'DB_PLATFORM', 'DB_USER', 'DB_PASS', 'DB_SCHEMA', 'DATA_FILES');

sub usage {
  my $envStr = '$' . join(", \$", @envVars);

  die "
Install an RNASeq user dataset into a website.

The dataset will include one or more .txt files (FPKM), and, optionally, parallel .bw files.  The
former are installed into the AppDB;  the latter into web service files.

Usage: install-data user_dataset_id filesDir
Where:
  user_dataset_id:  a user dataset id
  filesDir:         directory containing data files.  See import script for details.

ASSUMES THE DATASET IS PRE-VALIDATED DURING IMPORT.  See the import script.

Env: $envStr
";
}

my ($userDatasetId, $filesDir) = @ARGV;

usage() unless scalar(@ARGV) == 2;

for my $envVar (@envVars) { die "Missing env variable '$envVar'\n" unless $ENV{$envVar}; }

my $dbSchema = $ENV{DB_SCHEMA};

####################################################
# initialization for installing bw files to file sys
####################################################
my $datasetDir = $ENV{DATA_FILES};
die "Dataset target dir $datasetDir already exists\n" if -e $datasetDir;
mkdir($datasetDir) || die "Failed creating dataset target dir $datasetDir\n";
chmod(0775, $datasetDir) || die "Failed chmod of $datasetDir\n"; # rwxrwxr-x

##################################################
# initialization for installing txt files to appdb
##################################################
my $connectString = $ENV{DB_PLATFORM} eq 'Oracle'?
    "dbi:Oracle://$ENV{DB_HOST}:$ENV{DB_PORT}/$ENV{DB_NAME}" :
    "DBI:Pg:dbname=$ENV{DB_NAME};host=$ENV{DB_HOST};port=$ENV{DB_PORT}";

my $dbh = DBI->connect($connectString, $ENV{DB_USER}, $ENV{DB_PASS}) || die "Couldn't connect to database: " . DBI->errstr;

$dbh->{RaiseError} = 1;
$dbh->{AutoCommit} = 0;
my %profileSetIds;
my $orderNum = 1;
my $count = 0;
my ($panPkSh, $psPkSh, $insertProfileSet, $updateProfileSetUnit, $insertProtocolAppNode, $insertNaFeatureExpression, $unswitchProfiles)  = initializePreparedStmts();

#################################################################################
# discover reference genome and get mapping from provided id to na_feature_id
#################################################################################
my $orgNameForFiles = getRefGenome("$filesDir/meta.json");
my ($geneAliases, $transcriptIds) = getGeneAliases($dbh, $orgNameForFiles);


#################################################################################
# iterate through lines of manifest file, processing each file (either txt or bw)
#################################################################################

open(my $fh, "<:encoding(UTF-8)", "$filesDir/$MANIFEST_FILE") or die "Can't open manifest file '$filesDir/$MANIFEST_FILE' for reading:  $!";

# manifest file columns:
#    sampleName fileName strandInfo ('unstranded', 'sense' or 'antisense')
while(my ($panName, $filename, $strand) = readAndValidateManifestLine($fh, $filesDir)) {
  if ($filename =~ /(.+)\.txt$/) {
    my $fileGeneIds = validateTxtFileIds($filesDir, $filename, $geneAliases, $transcriptIds, $orgNameForFiles);
    $panName =~ s/\s+/_/g;
    installTxtFile($userDatasetId, $panName, $filesDir, $filename, $strand, $fileGeneIds);
  } else {
    BigWigUtils::installBwFile("$filesDir/$filename", $datasetDir);
  }
}

######################################
# do final processing for appdb
######################################
$unswitchProfiles->execute($userDatasetId);
$dbh->commit;



################################ subroutines   ##################################################################

sub initializePreparedStmts {

  my $panPkSql = $ENV{DB_PLATFORM} eq 'Oracle'?
      "select $dbSchema.UD_ProtocolAppNode_sq.nextval from dual":
      "select nextval('$dbSchema.UD_ProtocolAppNode_sq')";
  my $panPkSh = $dbh->prepare($panPkSql);

  my $psPkSql = $ENV{DB_PLATFORM} eq 'Oracle'?
      "select $dbSchema.UD_ProfileSet_sq.nextval from dual":
      "select nextval('$dbSchema.UD_ProfileSet_sq')";
  my $psPkSh = $dbh->prepare($psPkSql);

  my $insertProfileSet = $dbh->prepare(<<EOF);
    INSERT INTO $dbSchema.UD_ProfileSet
    (user_dataset_id, profile_set_id, name)
    VALUES (?,?,?)
EOF

  my $updateProfileSetUnit = $dbh->prepare(<<EOF);
    UPDATE $dbSchema.UD_ProfileSet
    SET unit = ?
    WHERE profile_set_id = ?
EOF

  my $insertProtocolAppNode = $dbh->prepare(<<EOF);
    INSERT INTO $dbSchema.UD_ProtocolAppNode
    (protocol_app_node_id, profile_set_id, name, node_order_num)
    VALUES (?,?,?,?)
EOF

  my $seqNxtVal = $ENV{DB_PLATFORM} eq 'Oracle'?
      "$dbSchema.UD_NaFeatureExpression_sq.nextval":
      "nextval('$dbSchema.UD_NaFeatureExpression_sq')";
      
  my $insertNaFeatureExpression = $dbh->prepare(<<EOF);
    INSERT INTO $dbSchema.UD_NaFeatureExpression
    (na_feat_expression_id, protocol_app_node_id, na_feature_id, value)
    VALUES ($seqNxtVal,?,?,?)
EOF

  # query to switch the sense of stranded data if sense.median < antisense.median
  my $unswitchProfiles = $dbh->prepare(<<EOF);
update $dbSchema.ud_ProfileSet
set name = case name
             when 'sense' then 'antisense'
             when 'antisense' then 'sense'
             else name
           end
where user_dataset_id = ?
  and user_dataset_id
      in (select sense.user_dataset_id
          from (select ps.user_dataset_id, PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY nfe.value) as median
                from $dbSchema.ud_NAFeatureExpression nfe,
                     $dbSchema.ud_ProfileSet ps,
                     $dbSchema.ud_ProtocolAppNode pan
                where ps.name = 'sense'
                  and ps.profile_set_id = pan.profile_set_id
                  and pan.protocol_app_node_id = nfe.protocol_app_node_id
                group by ps.user_dataset_id, ps.name) sense,
               (select ps.user_dataset_id, PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY nfe.value) as median
                from $dbSchema.ud_NAFeatureExpression nfe,
                     $dbSchema.ud_ProfileSet ps,
                     $dbSchema.ud_ProtocolAppNode pan
                where ps.name = 'antisense'
                  and ps.profile_set_id = pan.profile_set_id
                  and pan.protocol_app_node_id = nfe.protocol_app_node_id
                group by ps.user_dataset_id, ps.name) antisense
          where sense.user_dataset_id = antisense.user_dataset_id
            and sense.median < antisense.median)
EOF

    return ($panPkSh, $psPkSh, $insertProfileSet, $updateProfileSetUnit, $insertProtocolAppNode, $insertNaFeatureExpression, $unswitchProfiles);

}

sub validateTxtFileIds {
  my ($filedir, $filename, $geneAliases, $transcriptIds, $orgNameForFiles) = @_;

  print STDERR "validating txt file $filename\n" if $DEBUG;

  print STDERR "opening fpkm file $filename\n" if $DEBUG;
  open(DAT, "<:encoding(UTF-8)", "$filedir/$filename") or die "Cannot open file $filedir/$filename for reading: $!";

  # parse header to determine score column
  my $header = <DAT>;
  chomp($header);

  my $idIndex = 0;
  my $scoreIndex;

  if ($header =~ tr/\t// == 12) {        # Cufflinks FPKM file has 13 columns (12 delimiters)
    $scoreIndex = 9;
  } elsif ($header =~ /\t(.+)$/) {       # allow any column heading for the score column
    $scoreIndex = 1;
  } else {
    validationError("Unrecognized header record: '$header'.
Not a valid transcript abundance file. File: $filename");
  }

  # First pass: read all data and determine ID type
  my @fileData;
  my $geneIdCount = 0;
  my $transcriptIdCount = 0;
  my $unmappedCount = 0;

  while(<DAT>) {
    chomp;
    next unless $_;

    my @a = split(/\t/, $_);
    my $inputId = $a[$idIndex];
    my $score = $a[$scoreIndex];

    next unless $inputId;

    push(@fileData, [$inputId, $score]);

    # classify this ID
    if ($transcriptIds->{$inputId}) {
      $transcriptIdCount++;
    } elsif ($geneAliases->{$inputId}) {
      $geneIdCount++;
    } else {
      $unmappedCount++;
    }
  }
  close(DAT);

  # Determine mode: transcript, gene, or mixed
  my $isTranscriptMode = 0;
  if ($transcriptIdCount > 0 && $geneIdCount > 0) {
    validationError("File $filename has mixed ID types. There are $transcriptIdCount transcript IDs, but not all IDs are valid transcript IDs (found $geneIdCount gene aliases and $unmappedCount unmapped IDs).");
  } elsif ($transcriptIdCount > 0) {
    $isTranscriptMode = 1;
  }

  if ($isTranscriptMode) {
    # TRANSCRIPT MODE: sum scores by gene
    return validateAndProcessTranscriptIds(\@fileData, $transcriptIds, $filename, $orgNameForFiles);
  } else {
    # GENE MODE: existing logic
    return validateAndProcessGeneIds(\@fileData, $geneAliases, $filename, $orgNameForFiles);
  }
}

sub validateAndProcessTranscriptIds {
  my ($fileData, $transcriptIds, $filename, $orgNameForFiles) = @_;

  # track issues
  my @duplicateTranscriptIds;
  my @notMappedIds;
  my $duplicateCnt = 0;
  my $notMappedCnt = 0;

  my $seenTranscriptIds = {};
  my $geneIds = {};

  foreach my $row (@$fileData) {
    my ($inputId, $score) = @$row;

    # check for duplicate transcript IDs
    if ($seenTranscriptIds->{$inputId}) {
      push(@duplicateTranscriptIds, $inputId) unless @duplicateTranscriptIds >= 10;
      $duplicateCnt++;
      next;
    }
    $seenTranscriptIds->{$inputId} = 1;

    # check if mapped
    if (!$transcriptIds->{$inputId}) {
      push(@notMappedIds, $inputId) unless @notMappedIds >= 10;
      $notMappedCnt++;
      next;
    }

    # get gene for this transcript
    my $geneId = $transcriptIds->{$inputId}->{gene_id};
    my $naFeatureId = $transcriptIds->{$inputId}->{na_feature_id};

    # initialize gene entry if needed
    if (!$geneIds->{$geneId}) {
      $geneIds->{$geneId} = {
        na_feature_id => $naFeatureId,
        entries => []
      };
    }

    # add [transcriptId, score] pair - will sum later
    push(@{$geneIds->{$geneId}->{entries}}, [$inputId, $score]);
  }

  # report validation errors if any
  if ($duplicateCnt || $notMappedCnt) {
    my $errMsg = "Problems with provided transcript IDs in file $filename:\n";

    if ($duplicateCnt) {
      $errMsg .= "  $duplicateCnt transcript ID(s) are duplicated. For example: " . join(", ", @duplicateTranscriptIds) . "\n";
    }
    if ($notMappedCnt) {
      $errMsg .= "  $notMappedCnt ID(s) are not mappable to our $orgNameForFiles transcript IDs. For example: " . join(", ", @notMappedIds) . "\n";
    }
    validationError($errMsg);
  }

  # sum scores for each gene (convert entries to summed score)
  foreach my $geneId (keys %$geneIds) {
    my $entries = $geneIds->{$geneId}->{entries};
    my $sumScore = 0;
    foreach my $entry (@$entries) {
      $sumScore += $entry->[1];
    }
    # replace entries with a single summed entry
    $geneIds->{$geneId}->{entries} = [['summed', $sumScore]];
  }

  return $geneIds;
}

sub validateAndProcessGeneIds {
  my ($fileData, $geneAliases, $filename, $orgNameForFiles) = @_;

  # build gene-centric $geneIds structure
  my $geneIds = {};

  # track validation issues - only capture first 10 examples
  my @ambiguousIds;
  my @notMappedIds;
  my $ambiguousCnt = 0;
  my $notMappedCnt = 0;

  foreach my $row (@$fileData) {
    my ($inputId, $score) = @$row;

    # check if input ID maps to gene(s)
    if (!$geneAliases->{$inputId}) {
      push(@notMappedIds, $inputId) unless @notMappedIds >= 10;
      $notMappedCnt += 1;
      next;
    }

    # check if input ID is ambiguous (maps to multiple genes)
    if (@{$geneAliases->{$inputId}->{genes}} > 1) {
      push(@ambiguousIds, $inputId) unless @ambiguousIds >= 10;
      $ambiguousCnt += 1;
      next;
    }

    # get the single gene this input ID maps to
    my $geneId = $geneAliases->{$inputId}->{genes}->[0];
    my $naFeatureId = $geneAliases->{$inputId}->{feats}->[0];

    # initialize gene entry if needed
    if (!$geneIds->{$geneId}) {
      $geneIds->{$geneId} = {
        na_feature_id => $naFeatureId,
        entries => []
      };
    }

    # add [inputId, score] pair to this gene's entries
    push(@{$geneIds->{$geneId}->{entries}}, [$inputId, $score]);
  }

  # check for genes with clashing input IDs (different scores)
  my @clashingIdsPerGene;
  my $clashingCnt = 0;

  foreach my $geneId (keys %$geneIds) {
    my $entries = $geneIds->{$geneId}->{entries};

    if (@$entries > 1) {
      # check if all scores are the same
      my $firstScore = $entries->[0]->[1];
      my $hasDifferentScores = 0;

      for my $entry (@$entries) {
        if ($entry->[1] != $firstScore) {
          $hasDifferentScores = 1;
          last;
        }
      }

      if ($hasDifferentScores) {
        $clashingCnt += 1;
        if (@clashingIdsPerGene < 10) {
          my $exampleStr = "$geneId: ";
          $exampleStr .= join(", ", map { "$_->[0] (score: $_->[1])" } @$entries);
          push(@clashingIdsPerGene, $exampleStr);
        }
      }
    }
  }

  # report validation errors if any
  return $geneIds unless $notMappedCnt || $ambiguousCnt || $clashingCnt;

  my $errMsg = "Problems with provided IDs in file $filename:\n";

  if ($notMappedCnt) {
    $errMsg .= "  $notMappedCnt ID(s) are not mappable to our $orgNameForFiles gene IDs. For example: " . join(", ", @notMappedIds) . "\n";
  }
  if ($ambiguousCnt) {
    $errMsg .= "  $ambiguousCnt ID(s) map to more than one of our gene IDs. For example: " . join(", ", @ambiguousIds) . "\n";
  }
  if ($clashingCnt) {
    $errMsg .= "  $clashingCnt of our gene IDs have multiple input IDs with different scores. For example:\n    " . join("\n    ", @clashingIdsPerGene) . "\n";
  }
  validationError($errMsg);
}

sub installTxtFile {
  my ($userDatasetId, $panName, $filedir, $filename, $strand, $geneIds) = @_;

  print STDERR "installing txt file $filename\n" if $DEBUG;
  my $psId;
  if ($profileSetIds{$strand}) {
    $psId = $profileSetIds{$strand};
  }
  else {
    print STDERR "executing query psPkSh\n" if $DEBUG;
    $psPkSh->execute();
    ($psId) = $psPkSh->fetchrow_array();

    print STDERR "executing insert profile set $psId $strand\n" if $DEBUG;
    $insertProfileSet->execute($userDatasetId, $psId, $strand);

    $profileSetIds{$strand} = $psId;
  }

  print STDERR "executing query panPkSh\n" if $DEBUG;
  $panPkSh->execute();
  my ($panId) = $panPkSh->fetchrow_array();

  print STDERR "executing insert protocol app node $psId $panId $panName $orderNum\n" if $DEBUG;
  $insertProtocolAppNode->execute($panId, $psId, $panName, $orderNum);

  print STDERR "opening fpkm file $filename to read header\n" if $DEBUG;
  open(DAT, "<:encoding(UTF-8)", "$filedir/$filename") or die "Cannot open file $filedir/$filename for reading: $!";

  # check header to get unit
  my $header = <DAT>;
  chomp($header);
  close(DAT);

  my $unit;

  if ($header =~ tr/\t// == 12) {        # Cufflinks FPKM file has 13 columns (12 delimiters)
    $unit = "FPKM";
  } elsif ($header =~ /\t(.+)$/) { # allow any column heading for the count column.  typically FPKM or TPM
    $unit = $1;
  } else {
    validationError("Unrecognized header record: '$header'.
Not a valid transcript abundance file. File: $filename");
  }

  print STDERR "execute update profile set unit $psId $unit\n" if $DEBUG;
  $updateProfileSetUnit->execute($unit, $psId);

  print STDERR "iterate through geneIds, inserting to na feature expression for each gene.  commit every 1000 rows\n" if $DEBUG;

  my @panIdArray;
  my @naFeatureIdArray;
  my @fpkmArray;
  my $batchExecutor = new DbiBatchExecutor(1000, 1000, $ENV{DB_PLATFORM});
  my $cnt = 0;
  # loop through gene-centric $geneIds structure
  foreach my $geneId (keys %$geneIds) {
    $cnt += 1;
    my $naFeatureId = $geneIds->{$geneId}->{na_feature_id};
    my $entries = $geneIds->{$geneId}->{entries};

    # use first entry's score (validation ensures all scores match for this gene)
    my $score = $entries->[0]->[1];

    push(@panIdArray, $panId);
    push(@naFeatureIdArray, $naFeatureId);
    push(@fpkmArray, $score);
    $batchExecutor->periodicallyExecuteBatch($dbh, $insertNaFeatureExpression, 0, [SQL_INTEGER, SQL_INTEGER, SQL_DOUBLE], \@panIdArray, \@naFeatureIdArray, \@fpkmArray);
  }
  $batchExecutor->periodicallyExecuteBatch($dbh, $insertNaFeatureExpression, 1, [SQL_INTEGER, SQL_INTEGER, SQL_DOUBLE], \@panIdArray, \@naFeatureIdArray, \@fpkmArray);

  $orderNum++;
}

sub getGeneAliases {
  my ($dbh, $orgNameForFiles) = @_;

  my $sql = "select internal_abbrev from apidbtuning.organismattributes where name_for_filenames = '$orgNameForFiles'";

  print STDERR "execute query to get org_abbrev\n";
  my $sh = $dbh->prepare($sql);
  $sh->execute();
  my ($orgAbbrev) = $sh->fetchrow_array();
  validationError("Can't find organism $orgNameForFiles") unless $orgAbbrev;

  # map all gene aliases (not including transcripts) to the gene source_id and na_feature_id
  $sql = "SELECT a.gene AS gene_source_id, a.ID as alias, ga.na_feature_id
                FROM webready.GeneId_p a, webready.GeneAttributes_p ga
                WHERE ga.source_id = a.gene
                  AND ga.org_abbrev = '$orgAbbrev'
		  and a.org_abbrev = '$orgAbbrev'";

  print STDERR "execute query to map gene aliases to feature ids\n";
  $sh = $dbh->prepare($sql);
  $sh->execute();

  my $geneAliases = {};
  while(my ($sourceId, $alias, $naFeatureId) = $sh->fetchrow_array()) {
    if (!$geneAliases->{$alias}) {
      $geneAliases->{$alias}->{genes} = [];
      $geneAliases->{$alias}->{feats} = [];
    }
    push(@{$geneAliases->{$alias}->{genes}}, $sourceId);
    push(@{$geneAliases->{$alias}->{feats}}, $naFeatureId);
  }
  $sh->finish();

  # map transcript IDs to their gene source_id and na_feature_id
  $sql = "SELECT gene_source_id, ta.source_id as transcript_id, ga.na_feature_id
                FROM webready.transcriptattributes_p ta, webready.GeneAttributes_p ga
                WHERE ga.source_id = ta.gene_source_id
                  AND ga.org_abbrev = '$orgAbbrev'
		  and ta.org_abbrev = '$orgAbbrev'";

  print STDERR "execute query to map transcript ids to gene ids\n";
  $sh = $dbh->prepare($sql);
  $sh->execute();

  my $transcriptIds = {};
  while(my ($geneId, $transcriptId, $naFeatureId) = $sh->fetchrow_array()) {
    $transcriptIds->{$transcriptId} = {
      gene_id => $geneId,
      na_feature_id => $naFeatureId
    };
  }
  $sh->finish();

  return ($geneAliases, $transcriptIds);
}

sub validationError {
  my ($msg) = @_;

  print STDOUT "$msg\n";
  exit($VALIDATION_ERROR_CODE);
}

# return the orgNameForFiles of the genome declared as a dependency
sub getRefGenome {
  my ($metaJsonFile) = @_;

  my $json_text = do {
    open(my $json_fh, "<:encoding(UTF-8)", $metaJsonFile)
      or die("Can't open \"$metaJsonFile\": $!\n");
    local $/;
    <$json_fh>
  };

  my $json = JSON->new;
  my $metadata = $json->decode($json_text);

  my $dependencies = $metadata->{meta}->{dependencies};

  validationError("More than one reference genome") if (@$dependencies != 1);

  my $genomeIdentifier = $dependencies->[0]->{resourceIdentifier};

  # extract org name from eg PlasmoDB-51_Pfalciparum3D7_Genome
  $genomeIdentifier =~ /^[A-z]+-\d+_(.+)_Genome/ || validationError("Invalid genome resource format: $genomeIdentifier");
  my $orgNameForFiles = $1;
  return $orgNameForFiles;
}
