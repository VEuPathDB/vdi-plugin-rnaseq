#!/bin/bash

# ==============================================================================
# SETUP REQUIRED BEFORE RUNNING:
# ==============================================================================
# 1. Copy BigWigUtils.pm to lib/perl/
#    (This module is required for BigWig file handling)
#
# 2. Copy EncodingDetect.pm to lib/perl/
#    (This module is required for file encoding detection)
#
# 3. Comment out the isbigwig check in lib/perl/RnaSeqHandlerCommon.pm
#    (Test data uses empty placeholder BigWig files)
#    Look for the line that calls isbigwig() and comment it out
# ==============================================================================

# Usage
if [ $# -ne 1 ]; then
    echo "Usage: $0 <output_directory>"
    echo ""
    echo "Arguments:"
    echo "  output_directory  - Directory where test outputs will be stored"
    echo "                      Each test will create a subdirectory here"
    echo ""
    exit 1
fi

OUTPUT_BASE_DIR="$1"

# Create output directory if it doesn't exist
mkdir -p "$OUTPUT_BASE_DIR"

# Get the directory where this script is located
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECT_ROOT="$( cd "$SCRIPT_DIR/.." && pwd )"
IMPORT_BIN="$SCRIPT_DIR/import"
TEST_DATA_DIR="$PROJECT_ROOT/importTestData"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Counters
VALID_PASSED=0
VALID_FAILED=0
INVALID_PASSED=0
INVALID_FAILED=0

echo "========================================"
echo "RNA-Seq Import Validation Test Suite"
echo "========================================"
echo "Output directory: $OUTPUT_BASE_DIR"
echo ""

# Check if required files exist
if [ ! -f "$IMPORT_BIN" ]; then
    echo -e "${RED}ERROR: bin/import not found at $IMPORT_BIN${NC}"
    exit 1
fi

if [ ! -d "$TEST_DATA_DIR" ]; then
    echo -e "${RED}ERROR: Test data directory not found at $TEST_DATA_DIR${NC}"
    exit 1
fi

if [ ! -f "$PROJECT_ROOT/lib/perl/BigWigUtils.pm" ]; then
    echo -e "${YELLOW}WARNING: BigWigUtils.pm not found in lib/perl/${NC}"
    echo -e "${YELLOW}Please copy it as per setup instructions above${NC}"
fi

if [ ! -f "$PROJECT_ROOT/lib/perl/EncodingDetect.pm" ]; then
    echo -e "${YELLOW}WARNING: EncodingDetect.pm not found in lib/perl/${NC}"
    echo -e "${YELLOW}Please copy it as per setup instructions above${NC}"
fi

# Function to run a test
run_test() {
    local test_type="$1"  # "valid" or "invalid"
    local test_dir="$2"
    local test_name=$(basename "$test_dir")

    # Create subdirectory for this test's output
    local output_dir="$OUTPUT_BASE_DIR/${test_type}_${test_name}"

    # Clean and recreate the output directory
    rm -rf "$output_dir"
    mkdir -p "$output_dir"

    # Capture stdout (stderr goes to /dev/null)
    local stdout_file=$(mktemp)

    # Run the import
    local exit_code=0
    "$IMPORT_BIN" "$test_dir" "$output_dir" > "$stdout_file" 2>/dev/null || exit_code=$?

    # Print newline before test
    echo ""

    # Check result
    if [ "$test_type" = "valid" ]; then
        if [ $exit_code -eq 0 ]; then
            echo -e "${GREEN}✓${NC} VALID/$test_name - PASSED (import succeeded as expected)"
            ((VALID_PASSED++))
        else
            echo -e "${RED}✗${NC} VALID/$test_name - FAILED (import should have succeeded but failed with code $exit_code)"
            ((VALID_FAILED++))
        fi
    else
        if [ $exit_code -ne 0 ]; then
            echo -e "${GREEN}✓${NC} INVALID/$test_name - PASSED (import failed as expected)"
            ((INVALID_PASSED++))
        else
            echo -e "${RED}✗${NC} INVALID/$test_name - FAILED (import should have failed but succeeded)"
            ((INVALID_FAILED++))
        fi
    fi

    # Print stdout if any (indented with 4 spaces)
    if [ -s "$stdout_file" ]; then
        while IFS= read -r line; do
            echo "    $line"
        done < "$stdout_file"
    fi

    # Clean up temp file
    rm -f "$stdout_file"

    # Keep output for inspection (especially for valid tests to verify against manifest)
}

# Run valid tests
echo "Running VALID test cases..."
echo "-------------------------------------------"
if [ -d "$TEST_DATA_DIR/valid" ]; then
    for test_dir in "$TEST_DATA_DIR/valid"/*; do
        if [ -d "$test_dir" ]; then
            run_test "valid" "$test_dir"
        fi
    done
else
    echo -e "${YELLOW}No valid test directory found${NC}"
fi

echo ""

# Run invalid tests
echo "Running INVALID test cases..."
echo "-------------------------------------------"
if [ -d "$TEST_DATA_DIR/invalid" ]; then
    for test_dir in "$TEST_DATA_DIR/invalid"/*; do
        if [ -d "$test_dir" ]; then
            run_test "invalid" "$test_dir"
        fi
    done
else
    echo -e "${YELLOW}No invalid test directory found${NC}"
fi

echo ""
echo "========================================"
echo "Test Summary"
echo "========================================"
echo -e "Valid tests:   ${GREEN}$VALID_PASSED passed${NC}, ${RED}$VALID_FAILED failed${NC}"
echo -e "Invalid tests: ${GREEN}$INVALID_PASSED passed${NC}, ${RED}$INVALID_FAILED failed${NC}"
echo ""

TOTAL_PASSED=$((VALID_PASSED + INVALID_PASSED))
TOTAL_FAILED=$((VALID_FAILED + INVALID_FAILED))
TOTAL_TESTS=$((TOTAL_PASSED + TOTAL_FAILED))

echo -e "Total: $TOTAL_PASSED/$TOTAL_TESTS tests passed"

if [ $TOTAL_FAILED -eq 0 ]; then
    echo -e "${GREEN}All tests passed!${NC}"
    exit 0
else
    echo -e "${RED}Some tests failed${NC}"
    exit 1
fi
